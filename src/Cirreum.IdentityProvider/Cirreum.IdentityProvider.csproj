<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<Description>The Cirreum Identity Provider framework library — base registrar, configuration types, and user-provisioning contracts shared by identity-provider integrations (webhook callbacks, Entra External ID, etc.).</Description>
		<PackageTags>cirreum;identity;provisioning;providers</PackageTags>
	</PropertyGroup>

	<ItemGroup>
		<FrameworkReference Include="Microsoft.AspNetCore.App" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Cirreum.Providers" Version="1.0.113" />
	</ItemGroup>

	<ItemGroup>
		<Using Include="Cirreum.Providers" />
	</ItemGroup>

</Project>
